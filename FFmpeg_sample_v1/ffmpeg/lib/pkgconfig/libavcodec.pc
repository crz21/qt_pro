prefix=./ffmpeg_rk_build
exec_prefix=${prefix}
libdir=./ffmpeg_rk_build/lib
includedir=./ffmpeg_rk_build/include

Name: libavcodec
Description: FFmpeg codec library
Version: 60.31.102
Requires: 
Requires.private: libswresample >= 4.12.100, libavutil >= 58.29.100
Conflicts:
Libs: -L${libdir}  -lavcodec 
Libs.private: -pthread -lm -latomic -L./x264build/lib -lx264 -lpthread -lm -ldl
Cflags: -I${includedir}
