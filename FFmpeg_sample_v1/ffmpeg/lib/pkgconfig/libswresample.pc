prefix=./ffmpeg_rk_build
exec_prefix=${prefix}
libdir=./ffmpeg_rk_build/lib
includedir=./ffmpeg_rk_build/include

Name: libswresample
Description: FFmpeg audio resampling library
Version: 4.12.100
Requires: 
